#cloud-config
# Build-time only. Creates a temporary 'packer' user keyed to the ephemeral
# build key from prepare.sh. This user and its credentials are removed offline
# by finalize.sh and never ship in the golden image.
users:
  - default
  - name: packer
    groups: [sudo]
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
      - ${ssh_pubkey}

ssh_pwauth: false
package_update: false
package_upgrade: false
